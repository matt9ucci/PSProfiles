{
	"editor.renderWhitespace": "boundary",

	"files.insertFinalNewline": true,

	"terminal.integrated.copyOnSelection": true,

	"workbench.settings.editor": "json",
	"workbench.startupEditor": "none",

	"workbench.settings.applyToAllProfiles": [
		"editor.renderWhitespace",
		"files.insertFinalNewline",
		"terminal.integrated.copyOnSelection",
		"workbench.settings.editor",
		"workbench.startupEditor",
	],

	"[html]": {
		"editor.defaultFormatter": "vscode.html-language-features"
	},
	"[javascript]": {
		"editor.defaultFormatter": "vscode.typescript-language-features"
	},
	"[json]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "vscode.json-language-features"
	},
	"[typescript]": {
		"editor.defaultFormatter": "vscode.typescript-language-features"
	},
	"csharp.suppressBuildAssetsNotification": true,
	"csharp.suppressDotnetRestoreNotification": true,
	"debug.internalConsoleOptions": "openOnSessionStart",
	"diffEditor.renderSideBySide": false,
	"dotfiles.repository": "https://github.com/matt9ucci/dotfiles.git",
	"editor.acceptSuggestionOnCommitCharacter": false,
	"editor.cursorBlinking": "solid",
	"editor.fontFamily": "'Cascadia Mono PL', Consolas, 'Courier New', monospace",
	"editor.formatOnType": true,
	"editor.insertSpaces": false,
	"editor.tabCompletion": "on",
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"extensions.ignoreRecommendations": true,
	"files.associations": {
		"*.ps1xml": "xml"
	},
	"files.trimTrailingWhitespace": true,
	"git-graph.openNewTabEditorGroup": "Two",
	"git.enableSmartCommit": true,
	"javascript.format.semicolons": "remove",
	"json.schemas": [
		{
			"fileMatch": [
				"package.json"
			],
			"url": "http://json.schemastore.org/package"
		}
	],
	"markdown.extension.list.indentationSize": "inherit",
	"markdownlint.config": {
		"default": true,
		"no-hard-tabs": false,
		"MD004": {
			"style": "sublist"
		},
		"MD007": {
			"indent": 1
		}
	},
	"powershell.codeFormatting.newLineAfterCloseBrace": false,
	"powershell.codeFormatting.useConstantStrings": true,
	"powershell.codeFormatting.useCorrectCasing": true,
	"powershell.codeFormatting.whitespaceBetweenParameters": true,
	"powershell.integratedConsole.showOnStartup": false,
	"powershell.promptToUpdatePowerShell": false,
	"powershell.sideBar.CommandExplorerVisibility": false,
	"remote.containers.defaultExtensions": [
		"mhutchie.git-graph",
		"ms-vscode.powershell",
		"OnlyLys.leaper",
		"yzhang.markdown-all-in-one",
	],
	"remote.SSH.defaultExtensions": [
		"mhutchie.git-graph",
		"ms-vscode.powershell",
		"OnlyLys.leaper",
		"yzhang.markdown-all-in-one",
	],
	"remote.SSH.remotePlatform": {
		"primary.mshome.net": "linux"
	},
	"terminal.integrated.commandsToSkipShell": [
		"workbench.action.toggleSidebarVisibility",
	],
	"terminal.integrated.defaultProfile.linux": "pwsh",
	"terminal.integrated.defaultProfile.windows": "PowerShell",
	"terminal.integrated.enablePersistentSessions": false,
	"terminal.integrated.profiles.linux": {
		"pwsh": {
			"path": "pwsh",
			"args": [
				"-NoLogo"
			]
		}
	},
	"terminal.integrated.profiles.windows": {
		"PowerShell": {
			"source": "PowerShell",
			"args": [
				"-NoLogo"
			]
		}
	},
	"typescript.format.semicolons": "remove",
	"update.mode": "manual",
	"window.newWindowDimensions": "maximized",
	"window.restoreWindows": "none",
	"workbench.settings.useSplitJSON": true,
	"xml.format.preserveAttributeLineBreaks": true,
	"zenMode.hideLineNumbers": false,
}
